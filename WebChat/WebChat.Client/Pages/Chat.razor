@page "/chat"

<div class="tg-container">

    <!-- LEFT PANEL -->
    <div class="tg-sidebar">

        <div class="tg-search">
            <input placeholder="Search..." />
        </div>

        <div class="tg-chat-list">
            <div class="tg-chat active">
                <div class="avatar"></div>
                <div>
                    <b>General</b>
                    <p>Last message...</p>
                </div>
            </div>

            <div class="tg-chat">
                <div class="avatar"></div>
                <div>
                    <b>Dev Chat</b>
                    <p>Hello there</p>
                </div>
            </div>
        </div>

    </div>

    <!-- RIGHT PANEL -->
    <div class="tg-main">

        <!-- HEADER -->
        <div class="tg-header">
            <div class="avatar small"></div>
            <b>General</b>
        </div>

        <!-- MESSAGES -->
        <div class="tg-messages">

            <div class="msg other">Hello 👋</div>
            <div class="msg me">Hi!</div>

        </div>

        <!-- INPUT -->
        <div class="tg-input">
            <input placeholder="Type a message..." />
            <button>➤</button>
        </div>

    </div>

</div>