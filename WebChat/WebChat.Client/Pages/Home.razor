</section>

<!-- FINAL CTA -->
<section class="learn-section">

    <div class="info-block">
        <div class="info-text">
            <h2>Ready to start chatting?</h2>
            <p>
                Join now and experience real-time communication like never before.
            </p>

            <div style="margin-top: 20px;">
                <a href="/register" class="btn-primary">Create account</a>
                <a href="/login" class="btn-secondary">Login</a>
            </div>
        </div>
    </div>

</section>

<!-- FOOTER -->
<footer class="learn-section" style="padding-bottom: 40px;">

    <div style="opacity: 0.6;">
        © 2026 WebChat — Built for speed ⚡
    </div>

</footer>

    <script>
            window.addEventListener("scroll", () => {
                const hero = document.querySelector(".hero");

                const scrollY = window.scrollY;
                const maxScroll = 400;

                let opacity = 1 - scrollY / maxScroll;
                let translate = scrollY * 0.3;

                if (opacity < 0) opacity = 0;

                hero.style.opacity = opacity;
                hero.style.transform = `translateY(${translate}px)`;
            });
    </script>

</div>