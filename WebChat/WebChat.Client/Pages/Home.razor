@page "/"

<div class="home-container">

    <!-- HERO -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="fade-in">
                Simple. Fast. Real-time Chat.
            </h1>

            <p class="fade-in delay">
                Messaging and video calls in one clean interface.
            </p>

            <div class="hero-buttons fade-in delay-2">
                <a href="/Account/Register" class="btn-primary">Start chatting</a>
                <a href="#learn" class="btn-secondary">Learn more ↓</a>
            </div>
        </div>

        <div class="hero-bg"></div>
    </section>

    <!-- LEARN MORE -->
    <section id="learn" class="learn-section style-soft">

        <h2 class="section-title">Everything you need</h2>

        <div class="features">

            <div class="feature-card">
                <h3>💬 Real-time chat</h3>
                <p>Lightning-fast messaging that feels instant. No delays, no friction.</p>
            </div>

            <div class="feature-card">
                <h3>👥 Rooms</h3>
                <p>Create channels and organize conversations in a flexible, intuitive way.</p>
            </div>

            <div class="feature-card">
                <h3>📞 Video calls</h3>
                <p>Crystal-clear 1-on-1 calls with low latency, anytime, anywhere.</p>
            </div>

        </div>

    </section>

    <!-- MORE FEATURES -->
    <section class="learn-section style-contrast">

        <h2 class="section-title">Why choose WebChat?</h2>

        <div class="features">
            <div class="feature-card">
                <h3>⚡ Ultra fast</h3>
                <p>Messages delivered instantly with minimal delay and smooth animations.</p>
            </div>

            <div class="feature-card">
                <h3>🔒 Secure</h3>
                <p>End-to-end encryption keeps your conversations private and safe.</p>
            </div>

            <div class="feature-card">
                <h3>🌐 Cross-platform</h3>
                <p>Seamlessly switch between desktop, mobile, or browser without losing context.</p>
            </div>
        </div>

    </section>

    <!-- HISTORY -->
    <section class="learn-section style-glass">

        <h2 class="section-title">Our Story</h2>

        <div class="features">

            <div class="feature-card">
                <h3>🚀 2024 — The idea</h3>
                <p>We dreamed of a chat platform that is fast, minimal, and modern.</p>
            </div>

            <div class="feature-card">
                <h3>🛠️ 2025 — Development</h3>
                <p>Built with cutting-edge tech, focusing on speed, UX, and reliability.</p>
            </div>

            <div class="feature-card">
                <h3>🌍 Today</h3>
                <p>Now WebChat connects thousands of users daily with real-time communication.</p>
            </div>

        </div>

    </section>

   
    <footer class="learn-section style-footer">

        <div class="footer-text">
            © 2026 WebChat — Built for speed ⚡
        </div>

    </footer>

    <script>
            window.addEventListener("scroll", () => {
                const navbar = document.querySelector(".navbar");
                const bg = document.querySelector(".hero-bg");
                const sections = document.querySelectorAll("section");

                const scrollY = window.scrollY;

                // === HERO BG PARALLAX ===
                if (bg) {
                    bg.style.transform = `translateY(${scrollY * 0.4}px) scale(1.05)`;
                }

                // === SMOOTH NAVBAR (ВОТ ГЛАВНЫЙ ФИКС) ===
                if (navbar) {
                    const max = 200; // чем больше — тем медленнее затемнение
                    let progress = scrollY / max;

                    if (progress > 1) progress = 1;

                    navbar.style.background = `rgba(20,20,30, ${progress * 0.85})`;
                    navbar.style.backdropFilter = `blur(${progress * 10}px)`;
                }

                // === SECTION BACKGROUND SWITCH ===
                let current = 1;

                sections.forEach((sec, i) => {
                    const top = sec.offsetTop - 200;
                    if (scrollY >= top) {
                        current = i + 1;
                    }
                });

                document.body.className = "section-" + current;
            });
    </script>

</div>