@page "/"

<div class="home-container">

    <!-- HERO -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="fade-in">
                Simple. Fast. Real-time Chat.
            </h1>

            <p class="fade-in delay">
                Messaging and video calls in one clean interface.
            </p>

            <div class="hero-buttons fade-in delay-2">
                <a href="/register" class="btn-primary">Start chatting</a>
                <a href="#learn" class="btn-secondary">Learn more ↓</a>
            </div>
        </div>

        <div class="hero-bg"></div>
    </section>

    <!-- LEARN MORE -->
    <section id="learn" class="learn-section">

        <h2 class="section-title">Everything you need</h2>

        <div class="features">

            <div class="feature-card">
                <h3>💬 Real-time chat</h3>
                <p>Instant messaging with smooth performance.</p>
            </div>

            <div class="feature-card">
                <h3>👥 Rooms</h3>
                <p>Create channels and organize conversations.</p>
            </div>

            <div class="feature-card">
                <h3>📞 Video calls</h3>
                <p>1-on-1 calls with low latency.</p>
            </div>

        </div>

        <!-- extra section -->
        <div class="info-block">
            <div class="info-text">
                <h2>Built for speed</h2>
                <p>
                    Optimized for real-time communication using modern technologies.
                </p>
            </div>
        </div>

    </section>

</div>