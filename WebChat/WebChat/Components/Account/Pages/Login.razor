@page "/Account/Login"

@rendermode InteractiveServer


@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using WebChat.Data
@using Account.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager
@inject ILogger<Login> Logger
@inject IHttpClientFactory HttpFactory

<div class="auth-container">

    <div class="auth-card fade-scale">

        <h2>Sign in</h2>

        <EditForm Model="Input" OnValidSubmit="LoginUser">
            <DataAnnotationsValidator />

            <InputText @bind-Value="Input.Email"
                       placeholder="Email"
                       class="input" />
            <ValidationMessage For="() => Input.Email" />

            <InputText @bind-Value="Input.Password"
                       type="password"
                       placeholder="Password"
                       class="input" />
            <ValidationMessage For="() => Input.Password" />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <p style="color: #ff6b6b; margin-bottom:10px;">@errorMessage</p>
            }

            <button type="submit" class="btn-primary full">Login</button>

        </EditForm>

        <p class="auth-footer">
            Don’t have an account?
            <a href="/Account/Register">Sign up</a>
        </p>

    </div>

    <div class="auth-bg"></div>

</div>

@code {
    private LoginModel Input { get; set; } = new();
    private string? errorMessage;

    private async Task LoginUser()
    {
        var http = HttpFactory.CreateClient("api");

        var response = await http.PostAsJsonAsync("/api/login", Input);

        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo("/Chat", true);
        }
        else
        {
            errorMessage = "Invalid email or password.";
        }
    }

}