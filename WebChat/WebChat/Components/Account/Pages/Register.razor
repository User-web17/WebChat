@page "/Account/Register"

@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using WebChat.Data
@using Account.Models

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager
@inject ILogger<Register> Logger
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS

<div class="auth-container">

    <div class="auth-card fade-scale">

        <h2>Create account</h2>

        <EditForm Model="Input" OnValidSubmit="RegisterUser" FormName="register">
            <ValidationSummary />
            <DataAnnotationsValidator />

            <InputText @bind-Value="Input.Email"
                       placeholder="Email"
                       type="email"
                       class="input" />
            <ValidationMessage For="() => Input.Email" />

            <InputText @bind-Value="Input.Username"
                       placeholder="Username"
                       type="text"
                       class="input" />
            <ValidationMessage For="() => Input.Username" />

            <InputText @bind-Value="Input.Password"
                       type="password"
                       placeholder="Password"
                       class="input" />
            <ValidationMessage For="() => Input.Password" />

            <InputText @bind-Value="Input.ConfirmPassword"
                       type="password"
                       placeholder="Confirm password"
                       class="input" />
            <ValidationMessage For="() => Input.ConfirmPassword" />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <p style="color:#ff6b6b; margin-bottom:10px;">@errorMessage</p>
            }

            <button type="submit" class="btn-primary full">
                Create account
            </button>
        </EditForm>

        <p class="auth-footer">
            Already have an account?
            <a href="/Account/Login">Sign in</a>
        </p>

    </div>

    <div class="auth-bg"></div>

</div>

@code {
    private RegisterModel Input { get; set; } = new();
    private string? errorMessage;

    private async Task RegisterUser()
    {
        var http = HttpFactory.CreateClient("api");

        var response = await http.PostAsJsonAsync("/api/register", Input);

        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo("/Account/Login");
        }
        else
        {
            var errors = await response.Content.ReadFromJsonAsync<string[]>();
            errorMessage = string.Join(", ", errors ?? new[] { "Registration failed" });
        }
    }
}